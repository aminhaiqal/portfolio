---
import AsciiTerminal from "@/components/AsciiTerminal";
import AsciiTicker from "@/components/AsciiTicker.astro";
import ContactStarter from "@/components/ContactStarter.astro";
import FaqAccordion from "@/components/FaqAccordion";
import SEO from "@/components/seo/SEO.astro";
import Showcase from "@/components/Showcase.astro";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import MainLayout from "@/layouts/main.astro";

const siteTitle = "Axelyn Engineering Studio | Product, Platform, Automation";
const description =
  "Axelyn is an engineering studio where each build demonstrates high-performance software systems across product engineering, platform tooling, and automation.";
const canonical = "https://axelyn.com/";
const currentYear = new Date().getFullYear();

const faqItems = [
  {
    question: "What kind of clients do you work with?",
    answer:
      "Most engagements are with product and operations teams that need stronger software execution: shipping new systems, modernizing legacy workflows, or hardening delivery pipelines.",
  },
  {
    question: "How are engagements scoped?",
    answer:
      "I start with a compact discovery and architecture pass, then execute through milestone-based delivery with clear acceptance criteria and weekly demos.",
  },
  {
    question: "Can you work with an in-house engineering team?",
    answer:
      "Yes. Axelyn can operate as an embedded execution partner alongside internal teams, handling critical paths while syncing on architecture and standards.",
  },
  {
    question: "Do you handle post-launch ownership?",
    answer:
      "Yes. I offer stabilization windows, reliability support, and ongoing iteration retainers after initial launch.",
  },
  {
    question: "What is the typical timeline?",
    answer:
      "Studio sprints run in 2-week cycles. Most focused builds launch in 4 to 10 weeks depending on integration depth and organizational dependencies.",
  },
];

const operatingModel = [
  {
    title: "01 Discovery Sprint",
    body: "Map critical workflows, define delivery goals, and align on technical constraints.",
    detail: "Output: architecture brief + milestone plan",
  },
  {
    title: "02 Build Cycles",
    body: "Deliver production-ready increments in 2-week cycles with demos and decision checkpoints.",
    detail: "Output: shippable software every cycle",
  },
  {
    title: "03 Launch & Handover",
    body: "Production release, runbooks, training, and ownership transfer for engineering and operations.",
    detail: "Output: documented system with clear owners",
  },
];

const engagementTracks = [
  {
    title: "Showroom Build",
    body: "End-to-end build for a new product or internal system.",
    pace: "6-12 weeks",
  },
  {
    title: "Platform Upgrade",
    body: "Targeted modernization of delivery tooling and operational reliability.",
    pace: "4-8 weeks",
  },
  {
    title: "Embedded Solo Partner",
    body: "I plug directly into your roadmap to accelerate a critical initiative.",
    pace: "Monthly retainer",
  },
];

const pricingPlans = [
  {
    tier: "Starter Build",
    price: "from RM3,500",
    fit: "For first workflow improvements and MVP internal tools for Malaysia teams.",
    includes: [
      "1 focused workflow",
      "1-2 weeks delivery",
      "Core handover docs",
    ],
  },
  {
    tier: "Core System",
    price: "from RM9,800",
    fit: "For production-ready systems with integrations and role-based access.",
    includes: [
      "2-3 workflows",
      "3-6 weeks delivery",
      "Launch support included",
    ],
  },
  {
    tier: "Founding Partner",
    price: "RM2,500-RM6,500 (intro offer)",
    fit: "For early Malaysia clients: discounted delivery in exchange for testimonial or case study permission.",
    includes: [
      "Priority roadmap support",
      "Flexible milestone billing",
      "Weekly planning + demos",
    ],
  },
];
---

<MainLayout title={siteTitle}>
  <SEO slot="head" title={siteTitle} description={description} canonical={canonical} faq={faqItems} />

  <a href="#main-content" class="skip-link">Skip to content</a>

  <div class="booking-strip" aria-hidden="true">AXELYN ENGINEERING STUDIO · NOW BOOKING Q2 + Q3 2026</div>

  <header class="sticky top-0 z-20 border-b border-border/70 bg-background/88 backdrop-blur-md">
    <nav class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-5 py-4" aria-label="Main navigation">
      <a href="#top" class="brand">AXELYN / STUDIO</a>
      <ul class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
        <li><a href="#showcase">Work</a></li>
        <li><a href="#model">Operating model</a></li>
        <li><a href="#engagements">Engagements</a></li>
        <li><a href="#pricing">Pricing</a></li>
        <li><a href="#faq">FAQ</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </nav>
  </header>

  <main id="main-content" class="mx-auto max-w-6xl px-5 pb-24 md:pb-28">
    <section id="top" class="hero-stack py-16 md:py-24">
      <div class="space-y-5 text-center hero-reveal">
        <p class="hero-kicker">Small studio. Real machines. Built by Axelyn.</p>
        <h1 class="text-4xl leading-tight font-semibold tracking-tight text-foreground md:text-6xl">
          Custom software for how your team actually works
        </h1>
        <p class="mx-auto max-w-3xl text-base text-muted-foreground md:text-lg">
          Axelyn builds web apps, CLI tools, and automation that replace spreadsheets, scripts, and manual workflows.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a class="btn-primary" href="mailto:aminh@axelyn.com?subject=Engineering%20Showroom%20Engagement">Start a project</a>
          <a class="btn-secondary" href="#showcase">View example systems</a>
        </div>
      </div>

      <div class="hero-visuals mx-auto mt-10 w-full max-w-3xl space-y-5 md:mt-12">
        <AsciiTerminal client:visible />
      </div>
    </section>

    <Showcase />

    <section id="model" class="section-gap" aria-labelledby="model-heading">
      <AsciiTicker text=":: discovery sprint => build cycles => launch + transfer ::" />
      <h2 id="model-heading" class="section-title">Operating model</h2>
      <p class="section-intro">A lightweight model that keeps scope grounded and delivery momentum high.</p>
      <div class="grid gap-5 md:grid-cols-3">
        {
          operatingModel.map((step) => (
            <Card>
              <CardHeader>
                <CardTitle>{step.title}</CardTitle>
                <CardDescription>{step.body}</CardDescription>
              </CardHeader>
              <CardContent>
                <p class="meta-note">{step.detail}</p>
              </CardContent>
            </Card>
          ))
        }
      </div>
    </section>

    <section id="engagements" class="section-gap" aria-labelledby="engagements-heading">
      <AsciiTicker text="[studio build] [platform upgrade] [embedded solo partner]" />
      <h2 id="engagements-heading" class="section-title">Engagement formats</h2>
      <div class="grid gap-5 md:grid-cols-3">
        {
          engagementTracks.map((track) => (
            <article class="engagement-card">
              <p class="engagement-pace">{track.pace}</p>
              <h3>{track.title}</h3>
              <p>{track.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section id="pricing" class="section-gap" aria-labelledby="pricing-heading">
      <AsciiTicker text="$ transparent pricing // founder-friendly rates // talk-first approach $" />
      <h2 id="pricing-heading" class="section-title">Malaysia-friendly pricing from day one</h2>
      <p class="section-intro">
        I share pricing early so teams can decide quickly. If budget is tight, we can start with a smaller scoped milestone and prove value first.
      </p>
      <div class="pricing-grid">
        {
          pricingPlans.map((plan) => (
            <article class="pricing-card">
              <p class="pricing-tier">{plan.tier}</p>
              <p class="pricing-amount">{plan.price}</p>
              <p class="pricing-fit">{plan.fit}</p>
              <ul aria-label={`${plan.tier} details`}>
                {plan.includes.map((item) => <li>{item}</li>)}
              </ul>
            </article>
          ))
        }
      </div>
      <aside class="pricing-note" aria-label="Pricing reassurance">
        <p class="pricing-note-title">No-pressure first conversation</p>
        <p>
          We can do a short call to align on your goals before any agreement is made. After that, I will send a practical scope and exact RM quote.
        </p>
      </aside>
    </section>

    <section id="faq" class="section-gap" aria-labelledby="faq-heading">
      <AsciiTicker text="? studio faq stream ? studio faq stream ?" />
      <h2 id="faq-heading" class="section-title">Frequently asked questions</h2>
      <FaqAccordion items={faqItems} client:visible />
    </section>

    <section id="contact" class="section-gap" aria-labelledby="contact-heading">
      <h2 id="contact-heading" class="section-title">Bring your next system into the studio.</h2>
      <p class="text-xl font-semibold text-foreground md:text-2xl">
        <a href="mailto:aminh@axelyn.com">aminh@axelyn.com</a>
      </p>
      <p class="mt-2 max-w-2xl text-sm text-muted-foreground">
        Share your goals, architecture constraints, and timeline. You will get a practical response with proposed scope and next steps.
      </p>
      <p class="contact-trust-note mt-2 max-w-2xl text-sm text-muted-foreground">
        If you prefer, we can start with a short conversation first. No commitment required.
      </p>
      <div class="mt-6">
        <ContactStarter />
      </div>
    </section>
  </main>

  <footer class="site-footer border-t border-border/70">
    <div class="mx-auto max-w-6xl space-y-4 px-5 py-10 text-sm">
      <div class="footer-shell">
        <div class="footer-brand-block">
          <p class="footer-eyebrow">AXELYN / STUDIO</p>
          <h3>Build the system your team wishes it already had.</h3>
          <p>
            Independent engineering studio for product systems, platform tooling, and automation programs.
          </p>
          <div class="footer-chips" aria-label="Capabilities">
            <span>Product Systems</span>
            <span>Platform Tooling</span>
            <span>Automation</span>
          </div>
        </div>
        <aside class="footer-contact-card" aria-label="Contact details">
          <p class="footer-label">Contact</p>
          <p><a class="footer-email" href="mailto:aminh@axelyn.com">aminh@axelyn.com</a></p>
          <p class="footer-timezone">Timezone: Asia/Kuala_Lumpur</p>
          <div class="footer-actions">
            <a class="footer-btn" href="mailto:aminh@axelyn.com?subject=Engineering%20Showroom%20Engagement">Start a project</a>
            <a class="footer-link" href="#top">Back to top</a>
          </div>
        </aside>
      </div>
      <p class="footer-signoff">{currentYear} Axelyn Engineering Studio. Designed and engineered by Axelyn.</p>
    </div>
  </footer>
</MainLayout>

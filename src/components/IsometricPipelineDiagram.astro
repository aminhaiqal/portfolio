<svg
  class="pipeline-svg"
  viewBox="0 0 560 280"
  role="img"
  aria-labelledby="pipeline-title pipeline-desc"
  xmlns="http://www.w3.org/2000/svg"
>
  <title id="pipeline-title">Workflow automation system diagram</title>
  <desc id="pipeline-desc">
    Diagram showing API sources flowing into a pipeline, then processing, then report output.
  </desc>

  <defs>
    <linearGradient id="flowLine" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#d7ccc0" />
      <stop offset="100%" stop-color="#9a7440" />
    </linearGradient>
    <marker id="arrow" markerWidth="7" markerHeight="7" refX="5" refY="3.5" orient="auto">
      <path d="M0,0 L7,3.5 L0,7 Z" fill="#9a7440" />
    </marker>
  </defs>

  <g fill="#f8f4ee" stroke="#cfbfaa" stroke-width="1.2">
    <polygon points="48,72 118,54 188,72 118,90" />
    <polygon points="48,72 48,126 118,144 118,90" fill="#efe8dd" />
    <polygon points="118,90 188,72 188,126 118,144" fill="#e8decf" />

    <polygon points="208,72 278,54 348,72 278,90" />
    <polygon points="208,72 208,126 278,144 278,90" fill="#efe8dd" />
    <polygon points="278,90 348,72 348,126 278,144" fill="#e8decf" />

    <polygon points="368,72 438,54 508,72 438,90" />
    <polygon points="368,72 368,126 438,144 438,90" fill="#efe8dd" />
    <polygon points="438,90 508,72 508,126 438,144" fill="#e8decf" />
  </g>

  <g fill="#5f4a2e" font-size="12" font-family="var(--font-mono)">
    <text x="80" y="171">API SOURCES</text>
    <text x="245" y="171">PIPELINE + ETL</text>
    <text x="404" y="171">PROCESSING</text>
    <text x="401" y="219">REPORT OUTPUT</text>
  </g>

  <g stroke="url(#flowLine)" stroke-width="2" fill="none" marker-end="url(#arrow)">
    <path d="M188 98 L208 98" />
    <path d="M348 98 L368 98" />
    <path d="M438 150 L438 192" />
  </g>

  <g fill="#fffdf9" stroke="#cfbfaa" stroke-width="1.1">
    <rect x="388" y="192" width="100" height="46" rx="8" />
    <rect x="402" y="202" width="72" height="6" rx="2" fill="#eadfcd" />
    <rect x="402" y="214" width="54" height="6" rx="2" fill="#eadfcd" />
  </g>

  <g fill="#9a7440">
    <circle cx="88" cy="42" r="4" />
    <circle cx="248" cy="42" r="4" />
    <circle cx="408" cy="42" r="4" />
  </g>
</svg>
